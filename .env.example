# ===========================================
# EarthLog Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ===========================================

# Database Configuration
DB_USERNAME=earthlog
DB_PASSWORD=your_secure_database_password

# Google OAuth2 (optional - required for production)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT Configuration (must be at least 256 bits / 32 characters)
JWT_SECRET=your_jwt_secret_key_must_be_at_least_256_bits_long

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=earthlog
RABBITMQ_PASSWORD=your_secure_rabbitmq_password
RABBITMQ_VHOST=earthlog

# Email Configuration (optional - disabled by default)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@earthlog.com
MAIL_FROM_NAME=EarthLog
